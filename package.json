{
  "name": "engram-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Engram AI — a RAG + Agent Culture POC: a shared engineering-knowledge substrate that agents read AND write.",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @em/web dev",
    "build": "pnpm --filter @em/web build",
    "seed": "pnpm --filter @em/rag seed",
    "typecheck": "pnpm -r --parallel typecheck",
    "verify": "bash scripts/verify.sh",
    "mcp": "pnpm --filter @em/mcp-server start"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
